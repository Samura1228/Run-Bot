# ─────────────────────────────────────────────────────────────────────────────
# Run Bot — environment variables
# Copy this file to `.env` for local development and fill in real values.
# On Railway, set each of these as a service variable instead.
# ─────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather (required).
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Anthropic (Claude) API key from https://console.anthropic.com (required).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Claude vision-capable model id (optional; sensible default below).
# If you get a 404 not_found_error for the model, set ANTHROPIC_MODEL to a model
# ID your Anthropic account has access to (see your Anthropic Console).
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Sampling temperature for Anthropic calls (optional; default: omitted).
# Leave unset for newer models like claude-sonnet-5 that reject temperature;
# set e.g. 0 only for older models that support it.
#ANTHROPIC_TEMPERATURE=

# Full Google service-account JSON as a SINGLE-LINE string (required).
# Paste the entire contents of the downloaded key file here, on one line.
# Example (truncated): {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"run-bot@your-project.iam.gserviceaccount.com", ...}
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n","client_email":"run-bot@your-project.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# The spreadsheet ID of your target Google Sheet (required).
# Found in the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDEF

# Telegram chat/group id where leaderboards are posted (usually negative).
# OPTIONAL at first: you can leave this unset and boot the bot just to run the
# built-in /chatid command in your group, which replies with the chat ID.
# Copy that value here, then set it and redeploy. Until it's set, leaderboards
# are skipped (the bot logs a warning and keeps running).
TARGET_CHAT_ID=-1001234567890

# IANA timezone for scheduling & date logic (optional; default below).
TIMEZONE=Europe/Nicosia

# Minimum vision confidence to accept a verdict (optional; default 0.6).
MIN_CONFIDENCE=0.6

# Points awarded per confirmed run (optional; default 10).
POINTS_PER_RUN=10

# Comma-separated Telegram user IDs allowed to set/view OTHER users' plans
# (coaches), e.g. 123,456 (optional; blank/unset → no coaches). Non-integer
# entries are skipped with a warning. Use /whoami to find IDs (reply to a
# member's message to get theirs).
#COACH_IDS=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (optional; default INFO).
LOG_LEVEL=INFO